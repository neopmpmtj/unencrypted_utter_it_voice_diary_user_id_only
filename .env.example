# --- Django ---
# DJANGO_SETTINGS_MODULE=src.utter_it.settings.dev
# SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Local dev:  DATABASE_URL=postgresql://postgres:password@localhost:5432/voice_diary_dev
# Production: DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/voice_diary_dev

# --- Supabase (production only) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=sb_secret_xxxxx

# --- Redis & Celery ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CHANNEL_LAYERS_REDIS_HOST=127.0.0.1
CHANNEL_LAYERS_REDIS_PORT=6379
CHANNEL_LAYERS_REDIS_DB=2
PENDING_TRANSCRIPTION_REDIS_DB=3
PENDING_TRANSCRIPTION_REDIS_HOST=127.0.0.1
PENDING_TRANSCRIPTION_REDIS_PORT=6379

# --- Encryption (Google OAuth token storage only; Fernet key) ---
MASTER_ENCRYPTION_KEY=your-master-encryption-key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/src.accounts/google/callback/

# --- Email (Gmail SMTP) ---
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# --- AI ---
AI_OPENAI_API_KEY=sk-proj-your-api-key
# Batch Calendar (Pro/Ultra tier) - Google Gemini for multi-event extraction
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
AI_TRANSCRIPTION_PROMPT=Your transcription prompt here

# Classification: set to false to skip verifier LLM pass (saves API cost)
CLASSIFICATION_ENABLE_VERIFIER=false

#To disable normalization, set LOUDNESS_ENABLED to false.
LOUDNESS_ENABLED=false 

#To change the target loudness, set the following variables:
LOUDNESS_TARGET_I=-16.0
LOUDNESS_TARGET_TP=-1.5
LOUDNESS_TARGET_LRA=11.0

#To change the ffmpeg timeout, set the following variable:
LOUDNESS_FFMPEG_TIMEOUT=180

# --- Token Quotas (per-tier daily limits: input_tokens + output_tokens) ---
# TOKEN_QUOTA_FREE_TOKENS_PER_DAY=50000
# TOKEN_QUOTA_PRO_TOKENS_PER_DAY=200000
# TOKEN_QUOTA_ULTRA_TOKENS_PER_DAY=1000000

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ULTRA_MONTHLY=price_...
STRIPE_TRIAL_DAYS=14

# --- Local filesystem storage (optional; skips Google Drive for attachments / stored recordings) ---
# When true, set STORAGE_LOCAL_STORAGE_ROOT to an absolute path. Subfolders: attachments/, recordings/.
# STORAGE_SAVE_ATTACHMENTS_TO_LOCAL_FILESYSTEM=false
# STORAGE_LOCAL_STORAGE_ROOT=/var/lib/voice-diary/storage

# --- Speech Guard Gate (VAD before transcription) ---
# Set to true to enable; default off for safety
SPEECH_GUARD_ENABLED=false
SPEECH_GUARD_ANALYSIS_WINDOW_SECONDS=5
SPEECH_GUARD_FRAME_DURATION_MS=30
SPEECH_GUARD_FRAME_HOP_MS=15
SPEECH_GUARD_SAMPLE_RATE=16000
SPEECH_GUARD_ENERGY_MULTIPLIER=2.5
SPEECH_GUARD_MIN_ACTIVE_RATIO=0.15
SPEECH_GUARD_VARIANCE_MULTIPLIER=4.0
SPEECH_GUARD_ZCR_MULTIPLIER=1.5
SPEECH_GUARD_AMBIGUOUS_RATIO_LOW=0.10
SPEECH_GUARD_CALIBRATION_PERCENTILE=0.20
